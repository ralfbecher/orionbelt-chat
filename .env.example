# ── LLM Providers ──────────────────────────────────────────────
# Primary cloud provider (recommended)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# Local: mlx-openai-server on Apple Silicon (start with mlx-openai-server)
# MLX_BASE_URL=http://localhost:8000/v1
# MLX_DEFAULT_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit

# Local: Ollama (optional)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_DEFAULT_MODEL=qwen2.5:14b

# Direct provider keys (optional, bypass OpenRouter)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-...
# OPENAI_DEFAULT_MODEL=gpt-4o

# Default on startup
# accepts these 5 values: openrouter, mlx, ollama, anthropic, openai
DEFAULT_PROVIDER=openrouter

# ── System prompt ──────────────────────────────────────────────
# Path to the system prompt file (defaults to system_prompt.md in project root)
# SYSTEM_PROMPT_FILE=~/my_custom_prompt.md

# ── MCP server configuration ────────────────────────────────────
# Each value can be a local directory (stdio) or an HTTP(S) URL (remote):
#   Local:  ANALYTICS_SERVER_DIR=../orionbelt-analytics
#   Remote: ANALYTICS_SERVER_DIR=https://analytics.example.com/mcp
# ANALYTICS_SERVER_DIR=../orionbelt-analytics
# SEMANTIC_LAYER_SERVER_DIR=../orionbelt-semantic-layer-mcp
